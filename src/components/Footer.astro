---
const year = new Date().getFullYear();
const whatsappNumber = '56972901775'; // <-- REEMPLAZAR
const whatsappLink = `https://wa.me/${whatsappNumber}`;
const email = 'contacto@notebookrepair.cl';
---

<footer class="relative py-12 border-t" style="background-color: var(--color-base); border-color: var(--color-border);">
  <div class="absolute inset-x-0 top-0 h-px" style="background: linear-gradient(90deg, transparent, var(--color-neon), transparent); opacity: 0.5;"></div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div
            class="w-9 h-9 rounded-lg flex items-center justify-center"
            style="background: linear-gradient(135deg, var(--color-accent), var(--color-neon));"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-white">
              <rect x="2" y="4" width="20" height="13" rx="2"/>
              <line x1="2" y1="20" x2="22" y2="20"/>
              <line x1="9" y1="11" x2="15" y2="11"/>
            </svg>
          </div>
          <span class="font-display text-lg font-bold" style="color: var(--color-text-primary);">
            Notebook<span style="color: var(--color-neon);">Repair</span>
          </span>
        </div>
        <p class="text-sm leading-relaxed max-w-xs" style="color: var(--color-text-muted);">
          Servicio técnico especializado en notebooks con 15 años de experiencia en infraestructura TI corporativa.
        </p>
      </div>

      <!-- Links -->
      <div>
        <div class="font-mono text-[10px] uppercase tracking-widest mb-4" style="color: var(--color-text-dim);">
          Navegación
        </div>
        <ul class="space-y-2.5">
          {[
            { label: 'Servicios', href: '#servicios' },
            { label: 'Proceso', href: '#proceso' },
            { label: 'Preguntas frecuentes', href: '#faq' },
            { label: 'Contacto', href: '#contacto' },
          ].map((link) => (
            <li>
              <a href={link.href} class="text-sm transition-colors hover:opacity-80" style="color: var(--color-text-secondary);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <div class="font-mono text-[10px] uppercase tracking-widest mb-4" style="color: var(--color-text-dim);">
          Contacto directo
        </div>
        <ul class="space-y-2.5">
          <li>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="text-sm flex items-center gap-2 transition-colors hover:opacity-80" style="color: var(--color-text-secondary);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: var(--color-neon);">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.892a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`} class="text-sm flex items-center gap-2 transition-colors hover:opacity-80" style="color: var(--color-text-secondary);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-neon);">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              {email}
            </a>
          </li>
          <li>
            <div class="text-sm flex items-center gap-2" style="color: var(--color-text-secondary);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-neon);">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Santiago, Chile
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t flex flex-col sm:flex-row items-center justify-between gap-3" style="border-color: var(--color-border);">
      <p class="font-mono text-[11px]" style="color: var(--color-text-dim);">
        © {year} NotebookRepair.cl — Todos los derechos reservados.
      </p>
      <p class="font-mono text-[11px] flex items-center gap-2" style="color: var(--color-text-dim);">
        <span class="status-dot"></span>
        Servicio operativo
      </p>
    </div>
  </div>
</footer>
