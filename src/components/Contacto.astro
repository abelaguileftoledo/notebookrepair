---
const whatsappNumber = '56972901775'; // <-- REEMPLAZAR
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Hola%2C%20quiero%20cotizar%20una%20reparaci%C3%B3n`;
const email = 'contacto@notebookrepair.cl';
---

<section id="contacto" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- BG -->
  <div class="absolute inset-0" style="background-color: var(--color-base-2);"></div>
  <div class="absolute inset-0 bg-grid-dense opacity-30 pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-glow-neon opacity-40 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-5 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left -->
      <div>
        <div class="reveal chip mb-5">
          <span class="status-dot"></span>
          <span>Contacto</span>
        </div>
        <h2 class="reveal font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-6" style="color: var(--color-text-primary);">
          Conversemos sobre <span class="text-gradient-neon">tu equipo</span>.
        </h2>
        <p class="reveal text-lg leading-relaxed mb-8" style="color: var(--color-text-secondary);">
          Respondemos en menos de 24 horas hábiles. Cuéntanos qué le pasa a tu notebook y te decimos si tiene solución antes de cobrar nada.
        </p>

        <div class="reveal space-y-3">
          <!-- WhatsApp card -->
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="card-glass rounded-xl p-5 flex items-center gap-4 group cursor-pointer"
          >
            <div
              class="w-14 h-14 rounded-lg flex items-center justify-center flex-shrink-0 transition-transform group-hover:scale-110"
              style="background: linear-gradient(135deg, #25d366, #128c7e); box-shadow: 0 4px 16px rgba(37, 211, 102, 0.3);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="white">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.892a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-mono text-[10px] uppercase tracking-widest mb-1" style="color: var(--color-text-muted);">
                WhatsApp · Respuesta rápida
              </div>
              <div class="font-display text-lg font-bold" style="color: var(--color-text-primary);">
                Escríbenos por WhatsApp
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1 flex-shrink-0" style="color: var(--color-neon);">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>

          <!-- Email card -->
          <a
            href={`mailto:${email}`}
            class="card-glass rounded-xl p-5 flex items-center gap-4 group cursor-pointer"
          >
            <div
              class="w-14 h-14 rounded-lg flex items-center justify-center flex-shrink-0 transition-transform group-hover:scale-110"
              style="background: linear-gradient(135deg, var(--color-accent), var(--color-neon)); box-shadow: 0 4px 16px rgba(0, 102, 255, 0.3);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-mono text-[10px] uppercase tracking-widest mb-1" style="color: var(--color-text-muted);">
                Email · Respuesta &lt; 24 hrs
              </div>
              <div class="font-display text-lg font-bold truncate" style="color: var(--color-text-primary);">
                {email}
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1 flex-shrink-0" style="color: var(--color-neon);">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>

          <!-- Location card -->
          <div class="card-glass rounded-xl p-5 flex items-center gap-4">
            <div
              class="w-14 h-14 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background-color: rgba(0, 212, 255, 0.08); border: 1px solid rgba(0, 212, 255, 0.2);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-neon);">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-mono text-[10px] uppercase tracking-widest mb-1" style="color: var(--color-text-muted);">
                Zona de atención
              </div>
              <div class="font-display text-lg font-bold" style="color: var(--color-text-primary);">
                Santiago, Chile
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Visual element -->
      <div class="reveal relative hidden lg:block">
        <div class="card-glass rounded-2xl p-8 relative overflow-hidden" style="background: linear-gradient(135deg, rgba(17, 24, 39, 0.95), rgba(10, 14, 26, 0.98));">
          <!-- Background pattern -->
          <div class="absolute inset-0 bg-grid-dense opacity-50 pointer-events-none"></div>
          <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full" style="background: radial-gradient(circle, rgba(0, 212, 255, 0.15), transparent 70%);"></div>

          <div class="relative">
            <div class="font-mono text-[10px] uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
              // Antes de contactar
            </div>

            <div class="space-y-5">
              {[
                { label: 'Marca y modelo del equipo', n: '01' },
                { label: 'Síntoma o falla específica', n: '02' },
                { label: 'Cuándo empezó el problema', n: '03' },
                { label: 'Si tiene archivos importantes', n: '04' },
              ].map((item) => (
                <div class="flex items-start gap-4 group">
                  <span class="font-mono text-xs mt-1" style="color: var(--color-neon);">
                    [{item.n}]
                  </span>
                  <span class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                    {item.label}
                  </span>
                </div>
              ))}
            </div>

            <div class="mt-8 pt-6 border-t" style="border-color: var(--color-border);">
              <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">
                Con esta información el diagnóstico es más rápido y la cotización más precisa desde el primer mensaje.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
