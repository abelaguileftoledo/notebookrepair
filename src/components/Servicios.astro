---
const servicios = [
  {
    code: '01',
    title: 'Cambio de batería',
    desc: 'Reemplazo de baterías originales y reconstrucción de packs con celdas nuevas. Diagnóstico previo del estado real de tu batería.',
    icon: 'battery',
  },
  {
    code: '02',
    title: 'Upgrade SSD y RAM',
    desc: 'Migración de HDD a SSD (NVMe o SATA), ampliación de memoria. Tu notebook puede durar 4-5 años más con el upgrade correcto.',
    icon: 'cpu',
  },
  {
    code: '03',
    title: 'Mantención térmica',
    desc: 'Limpieza interna profunda, cambio de pasta térmica y pads. Reduce temperaturas hasta 25°C y elimina el throttling.',
    icon: 'thermometer',
  },
  {
    code: '04',
    title: 'Formateo + instalación',
    desc: 'Instalación de Windows o Linux con drivers, software esencial y respaldo de tus archivos. Sin pérdida de datos.',
    icon: 'disk',
  },
  {
    code: '05',
    title: 'Reparación de placa madre',
    desc: 'BIOS flash con programador CH341A, reparación de daño por líquido, reemplazo de chips Winbond y diagnóstico a nivel componente.',
    icon: 'chip',
  },
  {
    code: '06',
    title: 'Venta de equipos refurbished',
    desc: 'Notebooks reacondicionados con SSD, batería nueva y sistema operativo instalado. Garantía y soporte post-venta incluidos.',
    icon: 'laptop',
  },
];

const icons = {
  battery: `<rect x="2" y="7" width="16" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/><line x1="6" y1="11" x2="6" y2="13"/><line x1="10" y1="11" x2="10" y2="13"/>`,
  cpu: `<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="14" x2="22" y2="14"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="14" x2="4" y2="14"/>`,
  thermometer: `<path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4 4 0 1 0 5 0z"/>`,
  disk: `<line x1="22" y1="12" x2="2" y2="12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" y1="16" x2="6.01" y2="16"/><line x1="10" y1="16" x2="10.01" y2="16"/>`,
  chip: `<rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="7" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="17" cy="12" r="1.5"/>`,
  laptop: `<rect x="2" y="4" width="20" height="13" rx="2"/><line x1="2" y1="20" x2="22" y2="20"/>`,
};
---

<section id="servicios" class="relative py-24 lg:py-32">
  <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-5 lg:px-8">

    <!-- Section header -->
    <div class="max-w-3xl mb-16">
      <div class="reveal chip mb-5">
        <span class="status-dot"></span>
        <span>Servicios</span>
      </div>
      <h2 class="reveal font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-5" style="color: var(--color-text-primary);">
        Lo que hacemos por <span class="text-gradient-neon">tu equipo</span>.
      </h2>
      <p class="reveal text-lg leading-relaxed" style="color: var(--color-text-secondary);">
        Desde un formateo simple hasta reparación de placa madre a nivel componente. Cobertura completa, presupuesto transparente y sin sorpresas.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {servicios.map((s) => (
        <div class="reveal card-glass rounded-xl p-7 group cursor-default">
          <div class="flex items-start justify-between mb-6">
            <div
              class="w-12 h-12 rounded-lg flex items-center justify-center transition-all duration-300 group-hover:scale-110"
              style="background-color: rgba(0, 212, 255, 0.08); border: 1px solid rgba(0, 212, 255, 0.2);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-neon);" set:html={icons[s.icon]} />
            </div>
            <span class="font-mono text-xs tracking-wider" style="color: var(--color-text-dim);">/{s.code}</span>
          </div>

          <h3 class="font-display text-xl font-bold mb-3" style="color: var(--color-text-primary);">
            {s.title}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            {s.desc}
          </p>

          <!-- Bottom indicator -->
          <div class="mt-6 pt-5 border-t flex items-center justify-between" style="border-color: var(--color-border);">
            <span class="font-mono text-[10px] uppercase tracking-widest" style="color: var(--color-text-muted);">
              Cotización gratuita
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1" style="color: var(--color-neon);">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <div class="reveal mt-12 flex flex-col sm:flex-row items-start sm:items-center gap-4 p-6 rounded-xl" style="background-color: rgba(0, 102, 255, 0.06); border: 1px solid rgba(0, 102, 255, 0.2);">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: rgba(0, 212, 255, 0.12);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-neon);">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
        <strong style="color: var(--color-text-primary);">¿Tu problema no aparece en la lista?</strong> Diagnosticamos cualquier falla en notebooks. Escríbenos y te decimos si tiene solución antes de cobrar.
      </p>
    </div>
  </div>
</section>
