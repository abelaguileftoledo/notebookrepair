---
const navItems = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Contacto', href: '#contacto' },
];

const whatsappNumber = '56935865050'; // <-- REEMPLAZAR con tu número real (sin +)
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Hola%2C%20quiero%20cotizar%20una%20reparaci%C3%B3n`;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background-color: rgba(10, 14, 26, 0.75); backdrop-filter: blur(12px); border-bottom: 1px solid var(--color-border);"
>
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-[72px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div
          class="w-10 h-10 rounded-lg flex items-center justify-center transition-all duration-300 group-hover:scale-105"
          style="background: linear-gradient(135deg, var(--color-accent), var(--color-neon)); box-shadow: 0 4px 16px rgba(0, 102, 255, 0.35);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-white">
            <rect x="2" y="4" width="20" height="13" rx="2"/>
            <line x1="2" y1="20" x2="22" y2="20"/>
            <line x1="9" y1="11" x2="15" y2="11"/>
          </svg>
        </div>
        <div class="flex flex-col leading-tight">
          <span class="font-display text-lg lg:text-xl font-bold" style="color: var(--color-text-primary);">
            Notebook<span style="color: var(--color-neon);">Repair</span>
          </span>
          <span class="text-[10px] font-mono tracking-[0.18em] uppercase" style="color: var(--color-text-muted);">
            Santiago · Chile
          </span>
        </div>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="relative px-4 py-2 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/5"
            style="color: var(--color-text-secondary);"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 hover:scale-[1.03]"
          style="background-color: var(--color-accent); color: white; box-shadow: 0 4px 14px rgba(0, 102, 255, 0.4);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.892a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotizar ahora
        </a>

        <!-- Mobile menu button -->
        <button
          id="menu-btn"
          class="lg:hidden w-10 h-10 flex items-center justify-center rounded-md transition-colors hover:bg-white/5"
          aria-label="Abrir menú"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-primary);">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 pt-2 border-t" style="border-color: var(--color-border);">
      <nav class="flex flex-col gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-4 py-3 text-sm font-medium rounded-md transition-colors hover:bg-white/5"
            style="color: var(--color-text-secondary);"
          >
            {item.label}
          </a>
        ))}
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 mx-1 inline-flex items-center justify-center gap-2 px-4 py-3 text-sm font-semibold rounded-lg"
          style="background-color: var(--color-accent); color: white;"
        >
          Cotizar por WhatsApp
        </a>
      </nav>
    </div>
  </div>
</header>
