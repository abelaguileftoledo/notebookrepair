---
const whatsappNumber = '56935865050'; // <-- REEMPLAZAR
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Hola%2C%20quiero%20cotizar%20una%20reparaci%C3%B3n`;
---

<section class="relative pt-28 lg:pt-36 pb-20 lg:pb-32 overflow-hidden">
  <!-- Background layers -->
  <div class="absolute inset-0 bg-grid opacity-60"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-glow-blue opacity-70 pointer-events-none"></div>
  <div class="absolute top-32 right-0 w-[500px] h-[500px] bg-glow-neon opacity-50 pointer-events-none"></div>

  <!-- Decorative line -->
  <div class="absolute top-24 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, var(--color-border), transparent);"></div>

  <div class="relative max-w-7xl mx-auto px-5 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 items-center">

      <!-- Left: copy -->
      <div class="lg:col-span-7">
        <div class="reveal">
          <div class="chip mb-6">
            <span class="status-dot animate-pulse-glow"></span>
            <span>Servicio a domicilio · Santiago</span>
          </div>
        </div>

       <h1 class="reveal font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.05] mb-6" style="color: var(--color-text-primary);">
          Servicio técnico de notebooks<br/>
          con <span class="text-gradient-neon">15 años de experiencia corporativa</span>.<br/>
          A domicilio en Santiago.
        </h1>

        <p class="reveal text-lg lg:text-xl leading-relaxed mb-10 max-w-2xl" style="color: var(--color-text-secondary);">
          Servicio técnico especializado en notebooks con <strong style="color: var(--color-text-primary);">15 años de experiencia</strong> en infraestructura TI corporativa. Diagnóstico real, presupuesto sin compromiso y reparación con repuestos originales.
        </p>

        <div class="reveal flex flex-wrap items-center gap-3 mb-12">
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.892a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Solicitar cotización
          </a>
          <a href="#servicios" class="btn-secondary">
            Ver servicios
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

        <!-- Stats -->
        <div class="reveal grid grid-cols-3 gap-4 lg:gap-8 max-w-2xl pt-8 border-t" style="border-color: var(--color-border);">
          <div>
            <div class="font-display text-3xl lg:text-4xl font-bold" style="color: var(--color-neon);">15<span class="text-xl" style="color: var(--color-text-muted);">+</span></div>
            <div class="font-mono text-[11px] uppercase tracking-wider mt-1" style="color: var(--color-text-muted);">Años de experiencia</div>
          </div>
          <div>
            <div class="font-display text-3xl lg:text-4xl font-bold" style="color: var(--color-neon);">24<span class="text-xl" style="color: var(--color-text-muted);">h</span></div>
            <div class="font-mono text-[11px] uppercase tracking-wider mt-1" style="color: var(--color-text-muted);">Tiempo de respuesta</div>
          </div>
          <div>
            <div class="font-display text-3xl lg:text-4xl font-bold" style="color: var(--color-neon);">100<span class="text-xl" style="color: var(--color-text-muted);">%</span></div>
            <div class="font-mono text-[11px] uppercase tracking-wider mt-1" style="color: var(--color-text-muted);">Diagnóstico real</div>
          </div>
        </div>
      </div>

      <!-- Right: terminal/diagnostic mockup -->
      <div class="lg:col-span-5 reveal">
        <div class="relative">
          <!-- Glow behind -->
          <div class="absolute -inset-4 bg-glow-neon opacity-60 blur-2xl pointer-events-none"></div>

          <!-- Card -->
          <div class="relative card-glass rounded-xl overflow-hidden" style="background: linear-gradient(135deg, rgba(17, 24, 39, 0.9), rgba(10, 14, 26, 0.95));">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 px-4 py-3 border-b" style="border-color: var(--color-border); background-color: rgba(0, 0, 0, 0.3);">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full" style="background-color: #ff5f56;"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background-color: #ffbd2e;"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background-color: #27c93f;"></div>
              </div>
              <div class="flex-1 text-center font-mono text-[11px]" style="color: var(--color-text-muted);">
                diagnostico@notebookrepair:~$
              </div>
            </div>

            <!-- Terminal body -->
            <div class="p-5 lg:p-6 font-mono text-[13px] leading-relaxed space-y-1.5" style="color: var(--color-text-secondary);">
              <div><span style="color: var(--color-neon);">›</span> Iniciando diagnóstico...</div>
              <div class="pl-4">
                <span style="color: var(--color-success);">✓</span> <span style="color: var(--color-text-muted);">CPU:</span> Intel i5 · OK
              </div>
              <div class="pl-4">
                <span style="color: var(--color-success);">✓</span> <span style="color: var(--color-text-muted);">RAM:</span> 8GB DDR4 · OK
              </div>
              <div class="pl-4">
                <span style="color: var(--color-warning);">⚠</span> <span style="color: var(--color-text-muted);">SSD:</span> 87% wear · revisar
              </div>
              <div class="pl-4">
                <span style="color: #ef4444;">✗</span> <span style="color: var(--color-text-muted);">Batería:</span> 32% capacidad · reemplazar
              </div>
              <div class="pl-4">
                <span style="color: var(--color-warning);">⚠</span> <span style="color: var(--color-text-muted);">Térmica:</span> 92°C idle · mantención
              </div>
              <div class="pt-3 mt-3 border-t" style="border-color: var(--color-border);">
                <div><span style="color: var(--color-neon);">›</span> Presupuesto generado</div>
                <div class="pl-4 mt-1" style="color: var(--color-text-primary);">
                  Total estimado: <span class="font-bold" style="color: var(--color-neon);">$65.000 CLP</span>
                </div>
              </div>
              <div class="pt-1 flex items-center">
                <span style="color: var(--color-neon);">›</span>
                <span class="ml-2 inline-block w-2 h-4 ml-1 animate-blink" style="background-color: var(--color-neon);"></span>
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 lg:-left-6 card-glass rounded-lg px-4 py-2.5 animate-float" style="background-color: var(--color-surface);">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: rgba(16, 185, 129, 0.15);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success);">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold" style="color: var(--color-text-primary);">Garantía incluida</div>
                <div class="text-[10px] font-mono uppercase tracking-wider" style="color: var(--color-text-muted);">En todas las reparaciones</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
